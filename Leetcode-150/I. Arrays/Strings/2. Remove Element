        int validElementIndex = 0;
        int count = 0;
        for (int i = 0; i < nums.size(); i++) {
            if (nums[i] != val) {
                nums[validElementIndex] = nums[i];
                validElementIndex++;
                count++;
            }
        }
        return count;;
    }
};