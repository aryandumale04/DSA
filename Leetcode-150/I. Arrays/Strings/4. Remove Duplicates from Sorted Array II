class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        if (nums.size() <= 2) {
            return nums.size();
        } else {
        int count  = 2;
        int validElementIndex = 2;

        for (int i = 2; i < nums.size(); i++) {
            // kya ye element unique hai 
            if (nums[i] == nums[validElementIndex - 1] && nums[i] == nums[validElementIndex - 2]) {
                // na 
                continue;
            } else {
                nums[validElementIndex] = nums[i];
                count++;
                validElementIndex++;       
            }
        }
        return count;
        }


    }
};