class Solution {
public:
    int majorityElement(vector<int>& nums) {
        int n = nums.size();
        map<int,int> freqCount;
        for (int i = 0; i < n; i++) {
            freqCount[nums[i]]++;
        }
       
        int majCount = n / 2;
        for (auto it : freqCount) {
            if (it.second> majCount) {
               return it.first;
            }
        }


    return -1;



            //optimal approach  : boyer moore voting algorithm 
        int count  = 1;
        int candidate = nums[0];

        for (int i = 1; i < nums.size(); i++) {
            if (count == 0) {
                candidate = nums[i];
                count = 1;
            }
           else  if(nums[i] != candidate) count --;
            else count++;
        }
        return candidate;
    }
};