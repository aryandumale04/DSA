        //         }
        //         temp = temp -> next;
        //     }
        //     tail->next = NULL;

        // }


        // return dummy.next;


        // optimal approach : LL is sorted ,so duplicates are adjacent
        ListNode dummy(0);
        dummy.next = head;
        ListNode* prev = &dummy;
        ListNode* curr = head;

        while (curr != NULL) {
            if (curr -> next && curr -> val == curr -> next -> val) {
                // duplicate block starts from  here so skip THIS BLOCK ENTIRELY
                while (curr -> next && curr -> next -> val == curr -> val) {
                    curr = curr -> next;
                }
                prev -> next = curr -> next;
                curr = prev -> next;
            } else {
                // no duplicate block so just move ahead
                prev = curr;
                curr = curr -> next;
            }

        }
        return dummy.next;

    
    }
